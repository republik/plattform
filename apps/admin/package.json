{
  "name": "@orbiting/admin-app",
  "private": true,
  "version": "1.1.0",
  "engines": {
    "node": "24"
  },
  "scripts": {
    "dev": "concurrently \"PORT=3006 next dev\" \"yarn gql:types --watch\" \"panda --watch\"",
    "build": "panda && yarn gql:types && next build",
    "start": "next start",
    "analyze": "ANALYZE=true next build",
    "prepare": "panda codegen",
    "lint": "eslint --fix .",
    "gql:types": "graphql-codegen --config graphql/configs/codegen-dev.ts",
    "zat:setup": "docker compose build",
    "zat:dev": "docker compose up zat-server",
    "zat:package": "docker compose run --rm zat-package"
  },
  "dependencies": {
    "@apollo/client": "^3.13.8",
    "@next/bundle-analyzer": "^15.5.15",
    "@project-r/styleguide": "*",
    "@republik/icons": "*",
    "@republik/theme": "*",
    "@sentry/nextjs": "^9.32.0",
    "d3-format": "^1.4.5",
    "d3-time-format": "^2.3.0",
    "date-fns": "^2.22.1",
    "graphql": "^16.11.0",
    "lodash": "^4.17.21",
    "lodash.debounce": "^4.0.8",
    "lucide-react": "^1.6.0",
    "moment": "^2.29.1",
    "next": "^15.5.15",
    "prop-types": "^15.7.2",
    "radix-ui": "^1.4.3",
    "react": "^19.2.5",
    "react-autosize-textarea": "^5.0.1",
    "react-dom": "^19.2.5",
    "react-infinite-scroller": "^1.2.4",
    "react-textarea-autosize": "^7.1.2",
    "remark": "^10.0.1",
    "remark-react": "^5.0.1",
    "sonner": "^2.0.7",
    "validator": "^10.11.0",
    "zod": "^4.0.6"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "5.0.2",
    "@graphql-codegen/client-preset": "4.2.5",
    "@graphql-codegen/introspection": "4.0.3",
    "@graphql-codegen/schema-ast": "^4.0.0",
    "@graphql-typed-document-node/core": "^3.2.0",
    "@next/env": "^15.5.15",
    "@pandacss/dev": "^1.9.1",
    "@republik/eslint-config-frontend": "*",
    "@republik/tsconfig": "*",
    "@types/node": "24",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "concurrently": "^8.2.1"
  }
}

{
  "name": "@republik/ui",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean --out-dir dist",
    "dev": "tsup src/index.ts --format cjs,esm --dts --clean --out-dir dist --watch",
    "prepare": "yarn build"
  },
  "dependencies": {
    "@republik/theme": "*"
  },
  "peerDependencies": {
    "@base-ui/react": "^1.3.0",
    "lucide-react": "^0.563.0",
    "react": "^19.2.3"
  },
  "devDependencies": {
    "@base-ui/react": "^1.3.0",
    "lucide-react": "^0.563.0",
    "react": "^19.2.3",
    "tsup": "^8.5.0"
  },
  "sideEffects": false
}
